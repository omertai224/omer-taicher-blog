<!-- repo: omer-taicher-blog | קובץ: index.html -->
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>עומר טייכר · הבלוג</title>
<meta name="description" content="טיפים פשוטים לטכנולוגיה יומיומית. מחשבים, סמארטפונים ואינטרנט — בשפה ברורה.">
<link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --orange: #e8854a;
  --orange-deep: #c96a2a;
  --orange-bg: #c96a2a;
  --navy: #0d1f35;
  --navy2: #142030;
  --white: #fff;
  --mid-dark: rgba(255,255,255,0.55);
  --border-dark: rgba(255,255,255,0.09);
  --border-orange: rgba(255,255,255,0.15);
}
body { font-family:'Rubik',sans-serif; background:var(--navy); color:#fff; direction:rtl; }

/* NAV */
nav {
  padding:18px 60px;
  display:flex; align-items:center; justify-content:space-between;
  border-bottom:1px solid var(--border-dark);
  position:sticky; top:0;
  background:rgba(13,31,53,0.97);
  backdrop-filter:blur(12px); z-index:100;
}
.logo { font-size:1.1rem; font-weight:800; color:#fff; text-decoration:none; }
.logo span { color:var(--orange); }
.nav-cta {
  background:var(--orange); color:#fff; border:none;
  padding:9px 22px; border-radius:50px;
  font-size:0.85rem; font-weight:700; cursor:pointer; font-family:inherit;
  text-decoration:none; display:inline-block;
}

/* HERO */
.hero {
  display:grid; grid-template-columns:1fr 380px;
  min-height:52vh;
  border-bottom:1px solid var(--border-dark);
  background:var(--navy2);
  text-decoration:none; color:inherit;
  cursor:pointer; transition:filter 0.2s;
}
.hero:hover { filter:brightness(1.07); }
.hero-content {
  padding:56px 60px;
  display:flex; flex-direction:column; justify-content:center;
}
.hero-label {
  font-size:0.65rem; font-weight:700; letter-spacing:0.2em;
  color:var(--orange); text-transform:uppercase; margin-bottom:20px;
  display:flex; align-items:center; gap:10px;
}
.hero-label::before { content:''; width:28px; height:2px; background:var(--orange); display:block; }
.hero h1 {
  font-size:clamp(1.6rem,3vw,2.4rem);
  font-weight:900; line-height:1.2; color:#fff;
  margin-bottom:16px; letter-spacing:-0.02em;
}
.hero h1 em { font-style:normal; color:var(--orange); }
.hero-excerpt { font-size:0.92rem; color:var(--mid-dark); line-height:1.75; margin-bottom:28px; max-width:440px; }
.hero-read {
  display:inline-flex; align-items:center; gap:10px;
  color:#fff; font-weight:700; font-size:0.9rem;
  text-decoration:none; border-bottom:2px solid var(--orange);
  padding-bottom:3px; width:fit-content;
}
.hero-meta {
  margin-top:32px; padding-top:24px;
  border-top:1px solid var(--border-dark);
  display:flex; align-items:center; gap:16px;
  font-size:0.78rem; color:var(--mid-dark);
}
.hero-meta strong { color:#fff; }
.hero-img {
  position:relative; overflow:hidden;
  display:flex; align-items:center; justify-content:center;
  background:linear-gradient(135deg,#0d1f35,#1a3a5c);
  font-size:6rem;
  align-self:center;
  margin:24px;
  border-radius:16px;
  border:1px solid var(--border-dark);
}
.hero-img::before {
  content:''; position:absolute; inset:0;
  background:radial-gradient(circle at 40% 40%, rgba(232,133,74,0.15) 0%, transparent 65%);
  border-radius:16px;
}
.hero-img img { width:100%; height:100%; object-fit:cover; }
.hero-num {
  position:absolute; bottom:16px; right:16px;
  font-size:0.6rem; color:rgba(255,255,255,0.3); letter-spacing:0.1em;
}

/* POSTS HEADER */
.posts-header {
  padding:36px 60px 18px;
  display:flex; align-items:baseline; justify-content:space-between;
  border-bottom:1px solid var(--border-dark);
}
.posts-header h2 {
  font-size:0.65rem; font-weight:700;
  letter-spacing:0.2em; color:var(--mid-dark); text-transform:uppercase;
}
.posts-count { font-size:0.78rem; color:var(--mid-dark); }

/* POST ROW */
.post-row {
  display:grid;
  grid-template-columns:1fr 260px;
  min-height:220px;
  border-bottom:1px solid var(--border-dark);
  text-decoration:none; color:inherit;
  cursor:pointer;
  transition:filter 0.18s;
}
.post-row:hover { filter:brightness(1.1); }
.post-row:hover .row-arrow { background:rgba(255,255,255,0.15); transform:translateX(-4px); }
.post-row.blue { background:var(--navy2); }
.post-row.blue .post-row-img { background:linear-gradient(135deg,#0d1f35,#1a3a5c); }
.post-row.orange { background:var(--orange-bg); }
.post-row.orange .post-row-img { background:linear-gradient(135deg,#a85520,#e8854a); }
.post-row.orange .row-num { color:rgba(255,255,255,0.5); }
.post-row.orange .post-row-body p { color:rgba(255,255,255,0.72); }
.post-row.orange .row-time { color:rgba(255,255,255,0.6); }
.post-row.orange .row-arrow { border-color:rgba(255,255,255,0.25); }

.post-row-img {
  display:flex; align-items:center; justify-content:center;
  font-size:4rem; position:relative; overflow:hidden;
  border-right:1px solid rgba(255,255,255,0.07);
  aspect-ratio:1;
  align-self:center;
  margin:20px;
  border-radius:14px;
  order:2;
}
.post-row-img::after {
  content:''; position:absolute; inset:0;
  background:radial-gradient(circle at 40% 40%, rgba(255,255,255,0.05) 0%, transparent 70%);
  border-radius:14px;
}
.post-row-img img { width:100%; height:100%; object-fit:cover; position:absolute; inset:0; }

.post-row-body {
  padding:32px 40px 32px 24px;
  display:flex; flex-direction:column; justify-content:center; gap:12px;
  order:1;
}
.row-num {
  font-size:0.6rem; font-weight:700;
  color:rgba(255,255,255,0.35); letter-spacing:0.15em;
}
.post-row-body h3 {
  font-size:1.1rem; font-weight:800;
  color:#fff; line-height:1.38; letter-spacing:-0.01em;
}
.post-row-body p {
  font-size:0.85rem; line-height:1.7;
  color:rgba(255,255,255,0.55); max-width:500px;
}
.row-footer {
  display:flex; align-items:center; justify-content:space-between; margin-top:4px;
}
.row-time { font-size:0.72rem; color:rgba(255,255,255,0.38); }
.row-arrow {
  width:34px; height:34px; border-radius:50%;
  border:1.5px solid rgba(255,255,255,0.18);
  display:flex; align-items:center; justify-content:center;
  color:rgba(255,255,255,0.55); font-size:0.85rem; transition:all 0.2s;
}

/* LOAD MORE */
.load-more {
  padding:40px; text-align:center;
  border-bottom:1px solid var(--border-dark);
  background:var(--navy2);
}
.load-more-btn {
  background:transparent; color:rgba(255,255,255,0.7);
  border:1.5px solid rgba(255,255,255,0.18);
  padding:13px 36px; border-radius:50px;
  font-size:0.88rem; font-weight:600; cursor:pointer; font-family:inherit;
  transition:all 0.2s;
}
.load-more-btn:hover { border-color:var(--orange); color:var(--orange); }
.load-more-btn:disabled { opacity:0.4; cursor:default; }

/* CTA */
.cta-strip {
  background:var(--orange-bg);
  padding:44px 60px;
  display:flex; align-items:center; justify-content:space-between; gap:40px;
  border-bottom:1px solid var(--border-orange);
}
.cta-strip h3 { font-size:1.4rem; font-weight:800; color:#fff; }
.cta-strip p { font-size:0.88rem; color:rgba(255,255,255,0.8); margin-top:6px; }
.cta-btn-white {
  background:#fff; color:var(--orange-deep);
  border:none; padding:13px 32px; border-radius:50px;
  font-size:0.9rem; font-weight:800; cursor:pointer; font-family:inherit;
  white-space:nowrap; flex-shrink:0; transition:transform 0.2s;
  text-decoration:none; display:inline-block;
}
.cta-btn-white:hover { transform:scale(1.04); }

/* FOOTER */
footer {
  background:var(--navy2);
  padding:32px 60px;
  display:flex; align-items:center; justify-content:space-between;
  color:var(--mid-dark); font-size:0.8rem;
  border-top:1px solid var(--border-dark);
}
.footer-logo { font-size:1rem; font-weight:800; color:#fff; }
.footer-logo span { color:var(--orange); }

/* EMPTY STATE */
.empty-state {
  padding:80px 60px; text-align:center;
  color:var(--mid-dark); background:var(--navy2);
  border-bottom:1px solid var(--border-dark);
}

/* MOBILE */
@media(max-width:768px){
  nav { padding:14px 20px; }
  .hero { grid-template-columns:1fr; min-height:auto; }
  .hero-img { order:-1; margin:20px 20px 0; width:calc(100% - 40px); aspect-ratio:16/9; font-size:4rem; }
  .hero-content { padding:28px 20px 40px; }
  .posts-header { padding:24px 20px 14px; }
  .post-row { grid-template-columns:1fr; min-height:auto; }
  .post-row-img { order:-1; margin:16px 16px 0; width:calc(100% - 32px); aspect-ratio:16/9; border-right:none; font-size:3rem; }
  .post-row-body { padding:20px 20px 24px; }
  .cta-strip { flex-direction:column; padding:36px 20px; text-align:center; }
  footer { flex-direction:column; gap:10px; padding:24px 20px; }
  .load-more { padding:28px 20px; }
}
</style>
</head>
<body>

<nav>
  <a href="/" class="logo">עומר <span>טייכר</span> <span style="font-weight:400;color:rgba(255,255,255,0.45);font-size:0.9rem">· הבלוג</span></a>
  <a href="https://omer.tips" class="nav-cta">📞 צור קשר</a>
</nav>

<div id="hero-container"></div>

<div class="posts-header">
  <h2>כל הפוסטים</h2>
  <span class="posts-count" id="posts-count">טוען...</span>
</div>

<div id="posts-list"></div>

<div class="load-more" id="load-more-section" style="display:none;">
  <button class="load-more-btn" id="load-more-btn" onclick="loadMore()">טען עוד פוסטים ↓</button>
</div>

<div class="cta-strip">
  <div>
    <h3>יש לכם שאלה? אני כאן.</h3>
    <p>25 שנות ניסיון בשירות שלכם — בטלפון, בזום, או בביתכם.</p>
  </div>
  <a href="https://omer.tips" class="cta-btn-white">📞 דברו איתי</a>
</div>

<footer>
  <div class="footer-logo">עומר <span>טייכר</span></div>
  <span>© 2025 · כל הזכויות שמורות</span>
</footer>

<script>
const POSTS_PER_PAGE = 4;
let allPosts = [];
let displayedCount = 0;

function formatDate(dateStr) {
  const d = new Date(dateStr);
  const months = ['ינואר','פברואר','מרץ','אפריל','מאי','יוני','יולי','אוגוסט','ספטמבר','אוקטובר','נובמבר','דצמבר'];
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}

function renderHero(post) {
  const imgContent = post.image
    ? `<img src="${post.image}" alt="${post.title}">`
    : post.emoji;
  document.getElementById('hero-container').innerHTML = `
    <a class="hero" href="post.html?id=${post.id}">
      <div class="hero-content">
        <div class="hero-label">הפוסט האחרון</div>
        <h1>${post.title}</h1>
        <p class="hero-excerpt">${post.excerpt}</p>
        <span class="hero-read">קרא את הפוסט ←</span>
        <div class="hero-meta">
          <strong>עומר טייכר</strong>
          <span>·</span><span>${formatDate(post.date)}</span>
        </div>
      </div>
      <div class="hero-img">${imgContent}<div class="hero-num">01 / ${String(allPosts.length).padStart(2,'0')}</div></div>
    </a>`;
}

function renderPostRow(post, index, colorClass) {
  const imgContent = post.image
    ? `<img src="${post.image}" alt="${post.title}">`
    : post.emoji;
  return `
    <a class="post-row ${colorClass}" href="post.html?id=${post.id}">
      <div class="post-row-body">
        <span class="row-num">${String(index + 2).padStart(2,'0')}</span>
        <h3>${post.title}</h3>
        <p>${post.excerpt}</p>
        <div class="row-footer">
          <span class="row-time">${formatDate(post.date)}</span>
          <div class="row-arrow">←</div>
        </div>
      </div>
      <div class="post-row-img">${imgContent}</div>
    </a>`;
}

function loadMore() {
  const list = document.getElementById('posts-list');
  const remaining = allPosts.slice(displayedCount + 1, displayedCount + 1 + POSTS_PER_PAGE);
  remaining.forEach((post, i) => {
    const isLast = (i === remaining.length - 1);
    const colorClass = isLast ? 'blue' : (i % 2 === 0 ? 'orange' : 'blue');
    list.insertAdjacentHTML('beforeend', renderPostRow(post, displayedCount + i, colorClass));
  });
  displayedCount += remaining.length;
  const btn = document.getElementById('load-more-btn');
  const total = allPosts.length - 1;
  if (displayedCount >= total) {
    document.getElementById('load-more-section').style.display = 'none';
  } else {
    btn.textContent = `טען עוד פוסטים ↓ (${total - displayedCount} נותרו)`;
  }
}

async function init() {
  try {
    const res = await fetch('posts.json');
    const data = await res.json();
    allPosts = data.posts.sort((a, b) => new Date(b.date) - new Date(a.date));

    document.getElementById('posts-count').textContent = `${allPosts.length} פוסטים`;

    if (allPosts.length === 0) {
      document.getElementById('hero-container').innerHTML = '';
      document.getElementById('posts-list').innerHTML = '<div class="empty-state">אין פוסטים עדיין.</div>';
      return;
    }

    renderHero(allPosts[0]);

    const list = document.getElementById('posts-list');
    const firstBatch = allPosts.slice(1, 1 + POSTS_PER_PAGE);
    firstBatch.forEach((post, i) => {
      const isLast = (i === firstBatch.length - 1);
      const colorClass = isLast ? 'blue' : (i % 2 === 0 ? 'orange' : 'blue');
      list.insertAdjacentHTML('beforeend', renderPostRow(post, i, colorClass));
    });
    displayedCount = firstBatch.length;

    if (allPosts.length > 1 + POSTS_PER_PAGE) {
      document.getElementById('load-more-section').style.display = 'block';
      const remaining = allPosts.length - 1 - POSTS_PER_PAGE;
      document.getElementById('load-more-btn').textContent = `טען עוד פוסטים ↓ (${remaining} נותרו)`;
    }
  } catch(e) {
    document.getElementById('posts-count').textContent = '';
    console.error('Failed to load posts:', e);
  }
}

init();
</script>
</body>
</html>